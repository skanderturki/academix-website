# =============================================================================
# Droplet B — 165.232.175.224  (pmp · quality · gallery · bacinfo)
# Copy to `.env.droplet-b` on the droplet and fill in. Never commit the real file.
#   cp .env.droplet-b.example .env.droplet-b
#   docker compose -f docker-compose.droplet-b.yml --env-file .env.droplet-b up -d
#
# Vars marked [REQUIRED] use ${VAR:?} in the compose file — compose refuses to
# start if they're empty. Generate secrets with:  openssl rand -hex 32
# Mongo runs as a bundled container (no credentials needed on the internal net).
# =============================================================================

# --- pmp.academix.tn (PMP Learning Platform) -------------------------------
PMP_JWT_SECRET=                  # [REQUIRED]  openssl rand -hex 32
PMP_RESEND_API_KEY=              # optional — verification/notification emails
PMP_RESEND_FROM=PMP Learn <noreply@academix.tn>
# MONGODB_URI is wired to the shared mongo container in the compose file
# (mongodb://mongo:27017/pmp-learning) — no need to set it here.

# --- quality.academix.tn (Academic Quality Platform) -----------------------
QUALITY_JWT_SECRET=              # [REQUIRED]  openssl rand -hex 32
QUALITY_ADMIN_EMAIL=             # [REQUIRED]  seed admin login (change pw after first login)
QUALITY_ADMIN_PASSWORD=          # [REQUIRED]  strong password
QUALITY_CLIENT_URL=https://quality.academix.tn
# Optional — SMTP (password-reset OTP + notifications). Blank = disabled.
QUALITY_SMTP_HOST=
QUALITY_SMTP_PORT=587
QUALITY_SMTP_USER=
QUALITY_SMTP_PASS=
QUALITY_SMTP_FROM=
QUALITY_SMTP_SECURE=false
# Optional — Gemini (curriculum-PDF import + AI improvement summaries).
QUALITY_GEMINI_API_KEY=
# MONGODB_URI -> mongodb://mongo:27017/psu-quality (set in compose).

# --- gallery.jahiz.tn (nadart-evo) -----------------------------------------
NADART_JWT_SECRET=               # [REQUIRED]  openssl rand -hex 32
NADART_ADMIN_EMAIL=              # [REQUIRED]  gallery admin login
NADART_ADMIN_PASSWORD=           # [REQUIRED]  strong password
# Google sign-in (optional). Baked into the client bundle at BUILD time, so it
# must be present when you build the gallery image.
NADART_VITE_GOOGLE_CLIENT_ID=
NADART_GOOGLE_CLIENT_ID=
# n8n contact webhook (gallery posts contact form to n8n on Droplet A).
NADART_N8N_AUTH_USER=nadart
NADART_N8N_AUTH_PASSWORD=

# --- info.baximize.com (bacinfo) -------------------------------------------
# TODO: add vars here once bacinfo is relocated and its service is uncommented
# in docker-compose.droplet-b.yml.
