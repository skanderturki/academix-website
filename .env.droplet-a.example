# =============================================================================
# Droplet A — 178.128.51.137  (jahiz.tn · academix.tn · n8n.academix.tn)
# Copy to `.env.droplet-a` on the droplet and fill in. Never commit the real file.
#   cp .env.droplet-a.example .env.droplet-a
#   docker compose -f docker-compose.droplet-a.yml --env-file .env.droplet-a up -d
#
# Droplet A has NO hard-required vars (all have safe defaults), but the contact
# forms are dead until each site's RESEND_API_KEY is set.
# =============================================================================

# --- jahiz.tn (contact form via Resend) ------------------------------------
JAHIZ_RESEND_API_KEY=            # required for the jahiz.tn contact form to work
JAHIZ_RESEND_FROM=Jahiz <noreply@jahiz.tn>
JAHIZ_CONTACT_TO_EMAIL=contact@jahiz.tn
# Optional preview gate — leave SITE_PASSWORD blank to keep the site public.
JAHIZ_SITE_USERNAME=preview
JAHIZ_SITE_PASSWORD=

# --- academix.tn (contact form via Resend) ---------------------------------
MAIN_RESEND_API_KEY=             # required for the academix.tn contact form
MAIN_RESEND_FROM=Academix <noreply@academix.tn>
MAIN_CONTACT_TO_EMAIL=contact@academix.tn
MAIN_SITE_USERNAME=preview
MAIN_SITE_PASSWORD=

# --- n8n.academix.tn --------------------------------------------------------
# n8n is configured inline in the compose file (host/port/protocol). No vars
# needed here; its data persists in the `n8n_data` volume. Set up the owner
# account in the n8n UI on first visit.
